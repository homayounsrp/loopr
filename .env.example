# Loopr configuration — copy to .env (scripts/setup.sh does this for you).
# Every value here has a sensible default; a blank .env runs in client mode.

# ── Run mode ─────────────────────────────────────────────────────────────
# client = the backend makes ZERO LLM calls. A connected Claude client drives
#          the dashboard over the `loopr` MCP server. No API key needed. (default)
# api    = the backend runs the maker/checker agents itself on your API key.
LOOPR_MODE=client

# Default model the backend/agents use (api mode, and as a hint elsewhere).
LOOPR_MODEL=claude-sonnet-4-6

# ── Credentials (only needed when LOOPR_MODE=api) ────────────────────────
# A standard API key, OR an OAuth token from `claude` / `ant auth login`.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_AUTH_TOKEN=sk-ant-oat01-...

# ── Networking ───────────────────────────────────────────────────────────
# Backend URL the MCP server (backend/app/mcp_server.py) and scripts/dashctl.py
# proxy to. Change only if the backend runs on another host/port.
# LOOPR_URL=http://localhost:8000

# ── Frontend (Next.js) ───────────────────────────────────────────────────
# Point the dashboard at a non-default backend. Set these in frontend/.env.local.
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/factory
# NEXT_PUBLIC_API_URL=http://localhost:8000
