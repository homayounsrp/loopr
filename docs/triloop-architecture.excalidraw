    {
      "type": "text",
      "id": "r_base_t",
      "x": 158,
      "y": 1008,
      "width": 332.8,
      "height": 160.0,
      "text": "Base evals (always active):\n1. RendersEval  \u2014 bg/fg/headline present\n2. HasCtaEval   \u2014 cta length >= 3\n3. ContrastEval \u2014 ratio >= 4.5:1\n4. NoFillerEval \u2014 no filler words\n\n(the Coder must satisfy ALL of these\n every single build)",
      "originalText": "Base evals (always active):\n1. RendersEval  \u2014 bg/fg/headline present\n2. HasCtaEval   \u2014 cta length >= 3\n3. ContrastEval \u2014 ratio >= 4.5:1\n4. NoFillerEval \u2014 no filler words\n\n(the Coder must satisfy ALL of these\n every single build)",
      "fontSize": 16,
      "strokeColor": "#1e1e1e",
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "lineHeight": 1.25,
